<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Let's FioHub — просмотр видео</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f0f0f; color: #f1f1f1; }
        .header {
            position: fixed; top: 0; left: 0; right: 0; height: 56px;
            background: #0f0f0f; display: flex; align-items: center;
            justify-content: space-between; padding: 0 16px; z-index: 100;
            border-bottom: 1px solid #303030;
        }
        .logo { display: flex; align-items: center; gap: 8px; cursor: pointer; }
        .logo img { height: 32px; }
        .back-link { margin-left: 24px; color: #aaa; text-decoration: none; }
        .container { max-width: 1200px; margin: 80px auto 0; padding: 0 24px; }
        .video-wrapper { background: #000; border-radius: 16px; overflow: hidden; position: relative; }
        .video-wrapper video { width: 100%; max-height: 70vh; }
        .video-info-card { background: #1a1a1a; border-radius: 16px; padding: 20px; margin-top: 16px; }
        .video-title { font-size: 20px; font-weight: 600; margin-bottom: 12px; }
        .stats-row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; padding-bottom: 16px; border-bottom: 1px solid #303030; }
        .action-buttons { display: flex; gap: 12px; align-items: center; }
        .action-btn {
            background: #272727;
            border: none;
            color: white;
            padding: 8px 16px;
            border-radius: 40px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }
        .action-btn:hover { background: #3f3f3f; }
        .action-btn.liked { background: #ff0000; }
        .action-btn.disliked { background: #3f3f3f; color: #ff0000; }
        .channel-row { display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-bottom: 1px solid #303030; }
        .channel-info { display: flex; align-items: center; gap: 12px; cursor: pointer; }
        .channel-avatar { width: 48px; height: 48px; background: linear-gradient(135deg, #ff0000, #cc0000); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; }
        .channel-name { font-weight: 600; font-size: 16px; }
        .channel-subscribers { font-size: 12px; color: #aaa; }
        .subscribe-btn {
            background: #ff0000;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 600;
        }
        .subscribe-btn.subscribed { background: #272727; }
        .description { padding: 16px 0; font-size: 14px; color: #ccc; }
        .comments-section { margin-top: 24px; }
        .comment-form { display: flex; gap: 12px; margin-bottom: 24px; }
        .comment-form textarea { flex: 1; background: #121212; border: 1px solid #303030; border-radius: 20px; padding: 12px; color: white; font-family: inherit; resize: vertical; }
        .comment-form button { background: #ff0000; border: none; padding: 0 24px; border-radius: 40px; cursor: pointer; color: white; }
        .comment { background: #1a1a1a; padding: 16px; border-radius: 16px; margin-bottom: 12px; }
        .comment-author { font-weight: bold; margin-bottom: 8px; color: #ff0000; }
        .comment-text { margin-bottom: 8px; }
        .comment-meta { font-size: 12px; color: #aaa; display: flex; gap: 16px; margin-top: 8px; }
        .comment-like { cursor: pointer; }
        .comment-like:hover { color: #ff0000; }
        .loading { text-align: center; padding: 60px; color: #aaa; }
        
        /* Кнопка субтитров */
            position: absolute;
            bottom: 70px;
            right: 20px;
            background: #1a1a1a;
            border-radius: 12px;
            padding: 8px;
            z-index: 200;
            display: none;
            flex-direction: column;
            gap: 4px;
        }
            background: none;
            border: none;
            color: white;
            padding: 8px 20px;
            cursor: pointer;
            border-radius: 8px;
            font-size: 14px;
        }
            background: #272727;
            border: none;
            color: white;
            padding: 8px 16px;
            border-radius: 40px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        @media (max-width: 768px) { .container { padding: 0 16px; } }
/* Стили для меню настроек */
.settings-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 999; display: none; }
.settings-panel { position: fixed; top: 0; right: -400px; width: 380px; height: 100%; transition: right 0.3s; background: #1e1e1e; padding: 20px; border-radius: 10px; z-index: 1000; min-width: 300px; display: none; }
.settings-panel.active, .settings-overlay.active { display: block; }
.setting-item { margin: 15px 0; padding: 10px; border-bottom: 1px solid #333; }
.settings-btn { background: #4CAF50; color: white; border: none; padding: 8px 16px; border-radius: 5px; cursor: pointer; margin-top: 10px; }
.close-settings-btn { background: #666; }
.settings-icon { position: fixed; bottom: 20px; right: 20px; background: #333; color: white; border: none; padding: 12px 20px; border-radius: 50px; cursor: pointer; z-index: 100; font-size: 16px; }
.settings-icon:hover { background: #555; }

/* Боковое меню настроек как на главной странице */
.settings-panel.active { right: 0 !important; }
.settings-panel {
    position: fixed;
    top: 0;
    right: -400px;
    width: 380px;
    height: 100%;
    background: #1e1e1e;
    box-shadow: -2px 0 10px rgba(0,0,0,0.5);
    z-index: 1000;
    overflow-y: auto;
    transition: right 0.3s ease;
    padding: 20px;
}
.settings-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 20px;
    border-bottom: 1px solid #333;
    margin-bottom: 20px;
}
.close-settings {
    background: none;
    border: none;
    color: white;
    font-size: 24px;
    cursor: pointer;
}

    </style>
</head>
<body>

<header class="header">
    <div style="display: flex; align-items: center;">
        <div class="logo" onclick="window.location.href='/letsfiohub'">
            <img src="logo.png" alt="Logo">
            <span>Let's FioHub</span>
        </div>
        <a href="/letsfiohub" class="back-link">← На главную</a>
    </div>
</header>

<main class="container" id="app">
    <div class="loading">⏳ Загрузка видео...</div>
</main>

<script>
    const API_URL = 'https://letsfiohub-api.onrender.com';
    const urlParams = new URLSearchParams(window.location.search);
    const videoId = urlParams.get('id');
    let token = localStorage.getItem('token');
    let currentUser = null;
    let currentVideo = null;
    let comments = [];
    let hasLiked = false;
    let hasDisliked = false;
    let isSubscribed = false;
    let likeCount = 0;
    let dislikeCount = 0;
    let subscriberCount = 0;

    async function loadCurrentUser() {
        if (!token) return;
        try {
            const res = await fetch(`${API_URL}/api/me`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) currentUser = await res.json();
            else token = null;
        } catch(e) {}
    }

    async function loadVideo() {
        if (!videoId) {
            document.getElementById('app').innerHTML = '<div class="loading">❌ Видео не найдено</div>';
            return;
        }
        try {
            const headers = token ? { 'Authorization': `Bearer ${token}` } : {};
            const response = await fetch(`${API_URL}/api/videos/${videoId}`, { headers });
            if (response.ok) {
                currentVideo = await response.json();
                likeCount = currentVideo.likes || 0;
                dislikeCount = currentVideo.dislikes || 0;
                if (token) {
                    await checkLiked();
                    await checkSubscribed();
                }
                await loadComments();
                renderPage();
            } else {
                document.getElementById('app').innerHTML = '<div class="loading">❌ Видео не найдено</div>';
            }
        } catch (err) {
            document.getElementById('app').innerHTML = '<div class="loading">❌ Ошибка загрузки</div>';
        }
    }

    async function checkLiked() {
        try {
            const res = await fetch(`${API_URL}/api/videos/${videoId}/has_liked`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                const data = await res.json();
                hasLiked = data.liked;
                hasDisliked = data.disliked;
            }
        } catch(e) {}
    }

    async function checkSubscribed() {
        if (!currentVideo) return;
        try {
            const res = await fetch(`${API_URL}/api/is_subscribed/${currentVideo.uploader_id}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                const data = await res.json();
                isSubscribed = data.subscribed;
            }
            const subRes = await fetch(`${API_URL}/api/subscribers/${currentVideo.uploader_id}`);
            if (subRes.ok) {
                const subData = await subRes.json();
                subscriberCount = subData.count;
            }
        } catch(e) {}
    }

    async function likeVideo() {
        if (!token) { alert('Войдите, чтобы поставить лайк'); return; }
        if (hasLiked) { alert('Вы уже поставили лайк'); return; }
        try {
            const res = await fetch(`${API_URL}/api/videos/${videoId}/like`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                const data = await res.json();
                hasLiked = true;
                hasDisliked = false;
                likeCount = data.likes;
                dislikeCount = data.dislikes;
                updateButtons();
            }
        } catch(err) { alert('Ошибка'); }
    }

    async function dislikeVideo() {
        if (!token) { alert('Войдите, чтобы поставить дизлайк'); return; }
        if (hasDisliked) { alert('Вы уже поставили дизлайк'); return; }
        try {
            const res = await fetch(`${API_URL}/api/videos/${videoId}/dislike`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                const data = await res.json();
                hasDisliked = true;
                hasLiked = false;
                likeCount = data.likes;
                dislikeCount = data.dislikes;
                updateButtons();
            }
        } catch(err) { alert('Ошибка'); }
    }

    async function subscribe() {
        if (!token) { alert('Войдите, чтобы подписаться'); return; }
        try {
            const method = isSubscribed ? 'DELETE' : 'POST';
            const res = await fetch(`${API_URL}/api/subscribe/${currentVideo.uploader_id}`, {
                method: method,
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                const data = await res.json();
                isSubscribed = !isSubscribed;
                subscriberCount = data.subscribers_count;
                updateSubscribeButton();
            }
        } catch(err) { alert('Ошибка'); }
    }

    function goToChannel() {
        if (currentVideo && currentVideo.uploader_name) {
            window.location.href = `/letsfiohub/channel.html?username=${currentVideo.uploader_name}`;
        }
    }

    async function loadComments() {
        try {
            const res = await fetch(`${API_URL}/api/videos/${videoId}/comments`);
            if (res.ok) comments = await res.json();
        } catch(e) { comments = []; }
    }

    async function addComment() {
        const text = document.getElementById('commentText')?.value;
        if (!text || !text.trim()) return;
        if (!token) { alert('Войдите, чтобы оставить комментарий'); return; }
        try {
            const res = await fetch(`${API_URL}/api/videos/${videoId}/comments`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ text })
            });
            if (res.ok) {
                document.getElementById('commentText').value = '';
                await loadComments();
                renderComments();
        // addSubtitlesUploadButton(); // Удалено по требованию - субтитры только в настройках
            }
        } catch(err) { alert('Ошибка'); }
    }

    async function likeComment(commentId) {
        if (!token) { alert('Войдите'); return; }
        try {
            await fetch(`${API_URL}/api/comments/${commentId}/like`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            await loadComments();
            renderComments();
        // addSubtitlesUploadButton(); // Удалено по требованию - субтитры только в настройках
        } catch(err) {}
    }

    function shareVideo() {
        navigator.clipboard.writeText(window.location.href);
        alert('Ссылка скопирована!');
    }

    function toggleSubtitles() {
        const video = document.getElementById('videoPlayer');
        if (!video) return;
        
        
        // Ищем трек субтитров
        let track = null;
        for (let i = 0; i < video.textTracks.length; i++) {
                track = video.textTracks[i];
                break;
            }
        }
        
        if (track) {
        }
        
        if (subBtn) {
        }
    }

    function formatViews(views) {
        if (views >= 1000000) return (views/1000000).toFixed(1) + 'M';
        if (views >= 1000) return (views/1000).toFixed(1) + 'K';
        return views;
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function updateButtons() {
        const likeBtn = document.getElementById('likeBtn');
        const dislikeBtn = document.getElementById('dislikeBtn');
        document.getElementById('likeCount').textContent = likeCount;
        document.getElementById('dislikeCount').textContent = dislikeCount;
        if (hasLiked) likeBtn.classList.add('liked');
        else likeBtn.classList.remove('liked');
        if (hasDisliked) dislikeBtn.classList.add('disliked');
        else dislikeBtn.classList.remove('disliked');
    }

    function updateSubscribeButton() {
        const subBtn = document.getElementById('subscribeBtn');
        const subsSpan = document.getElementById('channelSubs');
        subBtn.textContent = isSubscribed ? '✓ Вы подписаны' : '🔔 Подписаться';
        if (isSubscribed) subBtn.classList.add('subscribed');
        else subBtn.classList.remove('subscribed');
        subsSpan.textContent = `${subscriberCount} подписчиков`;
    }

    function renderComments() {
        const commentsList = document.getElementById('commentsList');
        const commentsCount = document.getElementById('commentsCount');
        if (commentsCount) commentsCount.textContent = comments.length;
        if (commentsList) {
            commentsList.innerHTML = comments.map(c => `
                <div class="comment">
                    <div class="comment-author">${escapeHtml(c.author_name)}</div>
                    <div class="comment-text">${escapeHtml(c.text)}</div>
                    <div class="comment-meta">
                        <span>📅 ${new Date(c.created_at).toLocaleDateString()}</span>
                        <span class="comment-like" onclick="likeComment(${c.id})">❤️ ${c.likes || 0}</span>
                    </div>
                </div>
            `).join('');
        }
    }

    function renderPage() {
        if (!currentVideo) return;
        
        const isOwnChannel = currentUser && currentUser.id === currentVideo.uploader_id;
        
        document.getElementById('app').innerHTML = `
            <div class="video-wrapper">
                <video id="videoPlayer" controls autoplay>
                    <source src="${API_URL}/api/videos/${videoId}/stream" type="video/mp4">
                    Ваш браузер не поддерживает видео
                </video>
            </div>
            <div class="video-info-card">
                <h1 class="video-title">${escapeHtml(currentVideo.title) || 'Без названия'}</h1>
                <div class="stats-row">
                    <span id="viewsCount">👁️ ${formatViews(currentVideo.views)} просмотров</span>
                    <div class="action-buttons">
                        <button class="action-btn" id="likeBtn">👍 <span id="likeCount">${likeCount}</span></button>
                        <button class="action-btn" id="dislikeBtn">👎 <span id="dislikeCount">${dislikeCount}</span></button>
                        <button class="action-btn" id="shareBtn">🔗 Поделиться</button>
                    </div>
                </div>
                <div class="channel-row">
                    <div class="channel-info" id="channelLink">
                        <div class="channel-avatar">📺</div>
                        <div>
                            <div class="channel-name">${escapeHtml(currentVideo.uploader_name)}</div>
                            <div class="channel-subscribers" id="channelSubs">${subscriberCount} подписчиков</div>
                        </div>
                    </div>
                    ${!isOwnChannel ? `<button class="subscribe-btn ${isSubscribed ? 'subscribed' : ''}" id="subscribeBtn">${isSubscribed ? '✓ Вы подписаны' : '🔔 Подписаться'}</button>` : ''}
                </div>
                <div class="description">${escapeHtml(currentVideo.description) || 'Нет описания'}</div>
            </div>
            <div class="comments-section">
                <h3 style="margin-bottom: 16px;">💬 Комментарии <span id="commentsCount">${comments.length}</span></h3>
                ${token ? `
                    <div class="comment-form">
                        <textarea id="commentText" placeholder="Напишите комментарий..." rows="2"></textarea>
                        <button id="submitCommentBtn">Отправить</button>
                    </div>
                ` : '<p style="margin: 16px 0;"><a href="#" onclick="alert(\'Войдите, чтобы оставить комментарий\'); return false;">Войдите</a>, чтобы оставить комментарий</p>'}
                <div id="commentsList"></div>
            </div>
        `;
        
        // Привязываем обработчики
        document.getElementById('likeBtn').onclick = likeVideo;
        document.getElementById('dislikeBtn').onclick = dislikeVideo;
        document.getElementById('shareBtn').onclick = shareVideo;
        if (!isOwnChannel) document.getElementById('subscribeBtn').onclick = subscribe;
        document.getElementById('channelLink').onclick = goToChannel;
        if (token) document.getElementById('submitCommentBtn').onclick = addComment;
        
        // 
        if (subBtn) subBtn.onclick = toggleSubtitles;
        
        renderComments();
        // addSubtitlesUploadButton(); // Удалено по требованию - субтитры только в настройках
        
        // Применяем сохранённое состояние субтитров
        const video = document.getElementById('videoPlayer');
        if (video) {
            video.addEventListener('loadedmetadata', () => {
                for (let i = 0; i < video.textTracks.length; i++) {
                        break;
                    }
                }
            });
        }
    }

    async function init() {
        await loadCurrentUser();
        await loadVideo();
    }
    
    init();
</script>
<!-- Меню настроек -->
<div class="settings-overlay" id="settingsOverlay"></div>
<div class="settings-panel" id="settingsPanel">
    <div class="settings-header">
        <h3>Настройки</h3>
        <button class="close-settings" id="closeSettingsBtn">✕</button>
    </div>
    
    <div class="setting-item">
        <label>🎨 Тема</label>
        <select id="themeSelect">
            <option value="dark">Тёмная</option>
            <option value="light">Светлая</option>
        </select>
    </div>
    
    <div class="setting-item">
        <label>🔊 Качество видео</label>
        <select id="qualitySelect">
            <option value="auto">Авто</option>
            <option value="1080p">1080p</option>
            <option value="720p">720p</option>
        </select>
    </div>
    
    <div class="setting-item">
        <label>📝 Субтитры</label>
        <div>
            <label>
                <input type="checkbox" id="subtitlesToggle">
                Включить субтитры
            </label>
        </div>
        <div style="margin-top: 10px;">
            <button id="uploadSubtitlesBtn" class="settings-btn">📁 Загрузить VTT файл</button>
        </div>
    </div>
</div>
    
    <div class="setting-item">
        <label>📝 Субтитры</label>
        <div>
            <label>
                <input type="checkbox" id="subtitlesToggle">
                Включить субтитры
            </label>
        </div>
        <div style="margin-top: 10px;">
            <button id="uploadSubtitlesBtn" class="settings-btn">📁 Загрузить VTT файл</button>
        </div>
    </div>
    
    <div class="setting-item">
        <button id="closeSettingsBtn" class="settings-btn close-settings-btn">Закрыть</button>
    </div>
</div>

<script>
// Функции для меню настроек
function openSettings() {
    document.getElementById("settingsOverlay").classList.add("active");
    document.getElementById("settingsPanel").classList.add("active");
}

function closeSettings() {
    document.getElementById("settingsOverlay").classList.remove("active");
    document.getElementById("settingsPanel").classList.remove("active");
}

// Добавляем кнопку настроек
const settingsIcon = document.createElement("button");
settingsIcon.innerHTML = "⚙️ Настройки";
settingsIcon.className = "settings-icon";
settingsIcon.onclick = openSettings;
document.body.appendChild(settingsIcon);

// Закрытие по клику на оверлей
document.getElementById("settingsOverlay").onclick = closeSettings;
document.getElementById("closeSettingsBtn").onclick = closeSettings;

// Управление субтитрами
const subtitlesToggle = document.getElementById("subtitlesToggle");
if (subtitlesToggle) {
    subtitlesToggle.addEventListener("change", function(e) {
        const video = document.querySelector("video");
        if (video && video.textTracks.length > 0) {
            video.textTracks[0].mode = e.target.checked ? "showing" : "hidden";
        }
    });
}

// Загрузка субтитров
const uploadBtn = document.getElementById("uploadSubtitlesBtn");
if (uploadBtn) {
    uploadBtn.addEventListener("click", function() {
        const input = document.createElement("input");
        input.type = "file";
        input.accept = ".vtt";
        input.onchange = async (e) => {
            const file = e.target.files[0];
            const formData = new FormData();
            formData.append("subtitles", file);
            const videoId = new URLSearchParams(location.search).get("id");
            formData.append("videoId", videoId);
            
            try {
                const response = await fetch("/api/upload-subtitles", {
                    method: "POST",
                    body: formData
                });
                if (response.ok) {
                    alert("✅ Субтитры загружены! Страница обновится.");
                    location.reload();
                } else {
                    alert("❌ Ошибка загрузки");
                }
            } catch(err) {
                alert("❌ Ошибка: " + err.message);
            }
        };
        input.click();
    });
}

// Сохранение темы
const themeSelect = document.getElementById("themeSelect");
if (themeSelect) {
    const savedTheme = localStorage.getItem("theme");
    if (savedTheme) themeSelect.value = savedTheme;
    themeSelect.addEventListener("change", function(e) {
        localStorage.setItem("theme", e.target.value);
        if (e.target.value === "light") {
            document.body.style.background = "#fff";
            document.body.style.color = "#000";
        } else {
            document.body.style.background = "#0a0a0a";
            document.body.style.color = "#fff";
        }
    });
}
</script>

<script>
// Оптимизация загрузки видео
document.addEventListener("DOMContentLoaded", function() {
    const video = document.querySelector("video");
    if (video) {
        video.preload = "metadata";
        video.addEventListener("loadstart", function() {
            console.log("Видео начало загружаться");
        });
        video.addEventListener("canplay", function() {
            console.log("Видео готово к воспроизведению");
            document.querySelector(".loading")?.remove();
        });
    }
});
</script>
</body>
</html>
<script>
// Функция для загрузки субтитров
async function uploadSubtitles() {
    if (!token) {
        alert('Войдите, чтобы загрузить субтитры');
        return;
    }
    
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.vtt,.srt';
    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        const formData = new FormData();
        formData.append('file', file);
        
        try {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData
            });
            
            if (res.ok) {
                alert(' загружены! Обновите страницу, чтобы увидеть.');
                location.reload();
            } else {
                alert('Ошибка загрузки субтитров');
            }
        } catch(err) {
            alert('Ошибка: ' + err.message);
        }
    };
    input.click();
}

// Добавляем кнопку загрузки субтитров в интерфейс
    /* Функция addSubtitlesUploadButton удалена - субтитры только в настройках */
}
</script>

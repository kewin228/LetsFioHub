/* ========== ПЕРЕМЕННЫЕ ========== */
:root {
  --primary: #ff0000;
  --primary-dark: #cc0000;
  --bg-dark: #0f0f0f;
  --bg-light: #f9f9f9;
  --text-dark: #0f0f0f;
  --text-light: #ffffff;
  --gray: #606060;
  --gray-light: #e5e5e5;
  --sidebar-width: 240px;
}

[data-theme="dark"] {
  --bg: #0f0f0f;
  --text: #ffffff;
  --card-bg: #272727;
  --border: #3f3f3f;
}

[data-theme="light"] {
  --bg: #f9f9f9;
  --text: #0f0f0f;
  --card-bg: #ffffff;
  --border: #e5e5e5;
}

/* ========== ОБЩИЕ СТИЛИ ========== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
    'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
    sans-serif;
  background: var(--bg);
  color: var(--text);
}

.app {
  min-height: 100vh;
}

/* ========== ШАПКА ========== */
.header {
  background: var(--card-bg);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 0.75rem 0;
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.logo {
  font-size: 1.5rem;
  font-weight: bold;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--text);
}

.logo span {
  background: linear-gradient(135deg, #ff0000, #ff4444);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* ========== ПОИСК ========== */
.search-form {
  flex: 1;
  max-width: 600px;
  display: flex;
}

.search-form input {
  flex: 1;
  padding: 0.75rem 1rem;
  border: 1px solid var(--border);
  background: var(--bg);
  color: var(--text);
  border-radius: 40px 0 0 40px;
  font-size: 1rem;
}

.search-form input:focus {
  outline: none;
  border-color: var(--primary);
}

.search-form button {
  padding: 0.75rem 1.5rem;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-left: none;
  border-radius: 0 40px 40px 0;
  cursor: pointer;
  font-size: 1.2rem;
}

/* ========== НАВИГАЦИЯ ========== */
.nav-links {
  display: flex;
  gap: 1rem;
  align-items: center;
}

.nav-link {
  padding: 0.5rem 1rem;
  text-decoration: none;
  color: var(--text);
  border-radius: 40px;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.nav-link:hover {
  background: var(--border);
}

.btn-primary {
  background: var(--primary);
  color: white;
  padding: 0.5rem 1.5rem;
  border-radius: 40px;
  border: none;
  cursor: pointer;
  font-size: 0.9rem;
  transition: all 0.3s;
}

.btn-primary:hover {
  background: var(--primary-dark);
  transform: translateY(-2px);
}

/* ========== ГЛАВНАЯ ========== */
.hero {
  text-align: center;
  padding: 3rem 0;
  background: linear-gradient(135deg, #ff000020, #ff444420);
  border-radius: 1rem;
  margin-bottom: 2rem;
}

.hero h1 {
  font-size: 3rem;
  margin-bottom: 1rem;
  background: linear-gradient(135deg, #ff0000, #ff4444);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero p {
  font-size: 1.2rem;
  color: var(--gray);
}

/* ========== ВКЛАДКИ ========== */
.tabs {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
  border-bottom: 1px solid var(--border);
}

.tab, .tab-active {
  padding: 0.75rem 1.5rem;
  font-size: 1rem;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text);
  transition: all 0.3s;
}

.tab-active {
  color: var(--primary);
  border-bottom: 2px solid var(--primary);
}

/* ========== СЕТКА ВИДЕО ========== */
.videos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.video-card-link {
  text-decoration: none;
  color: inherit;
}

.video-card {
  background: var(--card-bg);
  border-radius: 0.75rem;
  overflow: hidden;
  transition: transform 0.3s;
  cursor: pointer;
}

.video-card:hover {
  transform: translateY(-4px);
}

.video-thumbnail {
  width: 100%;
  aspect-ratio: 16/9;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
}

.video-info {
  padding: 0.75rem;
}

.video-info h3 {
  font-size: 1rem;
  margin-bottom: 0.25rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.video-info p {
  font-size: 0.85rem;
  color: var(--gray);
  margin-bottom: 0.25rem;
}

.video-stats {
  display: flex;
  gap: 1rem;
  font-size: 0.8rem;
  color: var(--gray);
}

/* ========== СТРАНИЦА ПРОСМОТРА ========== */
.watch-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1rem;
}

.video-player {
  background: black;
  border-radius: 0.75rem;
  overflow: hidden;
  margin-bottom: 1.5rem;
}

.player {
  width: 100%;
  max-height: 70vh;
}

.video-info-section {
  margin-bottom: 2rem;
}

.video-info-section h1 {
  font-size: 1.5rem;
  margin-bottom: 1rem;
}

.video-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.like-btn {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 1rem;
  padding: 0.5rem 1rem;
  border-radius: 40px;
  color: var(--text);
  transition: all 0.3s;
}

.like-btn:hover {
  background: var(--border);
}

.video-description {
  padding: 1rem;
  background: var(--card-bg);
  border-radius: 0.75rem;
  margin-top: 1rem;
}

/* ========== КОММЕНТАРИИ ========== */
.comments-section {
  margin-top: 2rem;
}

.comments-section h3 {
  margin-bottom: 1rem;
}

.comment-form textarea {
  width: 100%;
  padding: 1rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 0.5rem;
  color: var(--text);
  font-family: inherit;
  resize: vertical;
  margin-bottom: 1rem;
}

.comment {
  background: var(--card-bg);
  padding: 1rem;
  border-radius: 0.5rem;
  margin-bottom: 1rem;
}

.comment-author {
  font-weight: bold;
  margin-bottom: 0.5rem;
  color: var(--primary);
}

.comment-text {
  margin-bottom: 0.5rem;
}

.comment-meta {
  font-size: 0.8rem;
  color: var(--gray);
}

/* ========== ФОРМЫ ========== */
.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
}

.auth-card {
  background: var(--card-bg);
  padding: 2rem;
  border-radius: 1rem;
  box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  width: 100%;
  max-width: 400px;
}

.auth-card h2 {
  text-align: center;
  margin-bottom: 1.5rem;
  color: var(--primary);
}

.auth-card input {
  width: 100%;
  padding: 0.75rem;
  margin: 0.5rem 0;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 0.5rem;
  color: var(--text);
}

.auth-card button {
  width: 100%;
  padding: 0.75rem;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 0.5rem;
  margin-top: 1rem;
  cursor: pointer;
  font-size: 1rem;
}

.auth-card p {
  text-align: center;
  margin-top: 1rem;
  color: var(--gray);
}

.auth-card a {
  color: var(--primary);
  text-decoration: none;
}

/* ========== ЗАГРУЗКА ВИДЕО ========== */
.upload-container {
  max-width: 600px;
  margin: 2rem auto;
}

.upload-form {
  background: var(--card-bg);
  padding: 2rem;
  border-radius: 1rem;
}

.form-group {
  margin-bottom: 1rem;
}

.form-group label {
  display: block;
  margin-bottom: 0.5rem;
  font-weight: bold;
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 0.75rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 0.5rem;
  color: var(--text);
  font-family: inherit;
}

/* ========== ПЛЕЙЛИСТЫ ========== */
.playlists-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
}

.playlists-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.playlist-card {
  background: var(--card-bg);
  padding: 1.5rem;
  border-radius: 0.75rem;
  transition: transform 0.3s;
}

.playlist-card:hover {
  transform: translateY(-4px);
}

.playlist-card h3 {
  margin-bottom: 0.5rem;
  color: var(--primary);
}

/* ========== ЗАГРУЗКА ========== */
.loading {
  text-align: center;
  padding: 3rem;
  color: var(--gray);
}

.empty-state {
  text-align: center;
  padding: 3rem;
  color: var(--gray);
}

/* ========== АДАПТИВНОСТЬ ========== */
@media (max-width: 768px) {
  .container {
    padding: 0 1rem;
  }
  
  .header-content {
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .search-form {
    order: 3;
    width: 100%;
  }
  
  .videos-grid {
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  }
  
  .hero h1 {
    font-size: 2rem;
  }
}

/* Theme Toggle */
.theme-toggle {
  background: var(--border);
  border: none;
  cursor: pointer;
  font-size: 1.2rem;
  padding: 0.5rem;
  border-radius: 50%;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.theme-toggle:hover {
  transform: rotate(15deg);
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 12px;
}

::-webkit-scrollbar-track {
  background: var(--bg);
}

::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 6px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--gray);
}

/* Logo styles */
.logo {
  text-decoration: none;
}

.logo-wrapper {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: linear-gradient(135deg, #ff0000, #ff4444);
  padding: 0.5rem 1rem;
  border-radius: 40px;
  transition: transform 0.3s;
}

.logo-wrapper:hover {
  transform: scale(1.02);
}

.logo-icon {
  font-size: 1.8rem;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-text span {
  font-size: 1.2rem;
  font-weight: bold;
  color: white;
  line-height: 1.2;
}

.logo-text small {
  font-size: 0.7rem;
  color: rgba(255,255,255,0.8);
  letter-spacing: 0.5px;
}

/* Responsive */
@media (max-width: 768px) {
  .logo-wrapper {
    padding: 0.4rem 0.8rem;
  }
  
  .logo-text span {
    font-size: 0.9rem;
  }
  
  .logo-text small {
    font-size: 0.6rem;
  }
  
  .logo-icon {
    font-size: 1.4rem;
  }
}

/* Logo styles */
.logo {
  text-decoration: none;
  display: flex;
  align-items: center;
}

.logo-image {
  height: 50px;
  width: auto;
  object-fit: contain;
  transition: transform 0.3s;
}

.logo-image:hover {
  transform: scale(1.02);
}

/* Responsive */
@media (max-width: 768px) {
  .logo-image {
    height: 35px;
  }
}

/* Logo styles - УВЕЛИЧЕННЫЙ ЛОГОТИП */
.logo {
  text-decoration: none;
  display: flex;
  align-items: center;
}

.logo-image {
  height: 70px;  /* Было 50px */
  width: auto;
  object-fit: contain;
  transition: transform 0.3s;
}

.logo-image:hover {
  transform: scale(1.05);
}

/* Еще больше на больших экранах */
@media (min-width: 1200px) {
  .logo-image {
    height: 85px;
  }
}

/* Адаптация для планшетов */
@media (max-width: 768px) {
  .logo-image {
    height: 45px;
  }
}

/* Для мобильных телефонов */
@media (max-width: 480px) {
  .logo-image {
    height: 35px;
  }
}

/* Увеличиваем высоту шапки */
.header {
  padding: 0.5rem 0;  /* Было 0.75rem */
}

.header-content {
  min-height: 85px;  /* Фиксированная минимальная высота */
}

/* На больших экранах */
@media (min-width: 1200px) {
  .header {
    padding: 0.75rem 0;
  }
  
  .header-content {
    min-height: 100px;
  }
}

/* Логотип занимает больше места */
.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.logo {
  flex-shrink: 0;  /* Логотип не сжимается */
}

.logo-image {
  height: 80px;
  width: auto;
  max-width: 280px;  /* Максимальная ширина */
}

/* Поиск растягивается */
.search-form {
  flex: 2;
  max-width: 600px;
}

/* Навигация не сжимается */
.nav-links {
  flex-shrink: 0;
}
